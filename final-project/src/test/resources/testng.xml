<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SauceDemo Automation Suite" verbose="1" parallel="none">

    <listeners>
        <listener class-name="com.saucedemo.listeners.TestListener"/>
    </listeners>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  GROUP 1 : Login Tests                                      -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <test name="Login Tests">
        <classes>
            <class name="com.saucedemo.tests.LoginTest"/>
        </classes>
    </test>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  GROUP 2 : Inventory / Product Tests                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <test name="Inventory Tests">
        <classes>
            <class name="com.saucedemo.tests.InventoryTest"/>
        </classes>
    </test>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  GROUP 3 : End-to-End Checkout Tests                        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <test name="Checkout Tests">
        <classes>
            <class name="com.saucedemo.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>
